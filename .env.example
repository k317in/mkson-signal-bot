# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Signal CLI REST API (future integration)
SIGNAL_CLI_REST_URL=http://localhost:8080
SIGNAL_BOT_NUMBER=+10000000000
SIGNAL_GROUP_ID=

# Google Sheets API
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_APPLICATION_CREDENTIALS=./config/google-service-account.json
# Alternative to GOOGLE_APPLICATION_CREDENTIALS:
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_EVENT_SHEET=event
GOOGLE_SHEETS_SIGNUP_SHEET=signup
GOOGLE_SHEETS_TEMPLATE_SHEET=template

# Admin configuration (hardcoded initially per docs)
ADMIN_NUMBERS=+10000000000
